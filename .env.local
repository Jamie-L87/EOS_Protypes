# EOS Cloud Import Module — Local Development Configuration
# This file is NOT committed to git.

# API base URL
VITE_API_BASE_URL=http://localhost:50905

# API authorisation key - UPDATE THIS with your actual key
VITE_API_AUTH_KEY=your_auth_key_here

# Item Detail lookup parameters
# These must match a valid dealer in the EOS system
VITE_SITE_ID=UK
VITE_DEALER_ID=D066080
VITE_LANGUAGE_ID=EN
VITE_CURRENCY=GBP
VITE_CUST_PRICE_CODE=
VITE_IGNORE_PL=1
