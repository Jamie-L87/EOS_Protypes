# EOS Cloud Import Module — Environment Configuration
# Copy this file to .env.local and fill in the values.
# .env.local is NOT committed to git.

# -------------------------------------------------------------------
# API base URL
# For local dev the Vite proxy forwards /api/* to this host.
# Leave as-is when running Eos.WebAPI locally on the default port.
# -------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:50905

# -------------------------------------------------------------------
# API authorisation key
# This is the value the Eos.WebAPI reads from AWS Secrets Manager.
# Ask your team lead for the dev/UAT value — never commit this.
# -------------------------------------------------------------------
VITE_API_AUTH_KEY=your_auth_key_here

# -------------------------------------------------------------------
# Item Detail lookup parameters
# These must match a valid dealer in the EOS system.
# Example: VITE_DEALER_ID=D066080
# -------------------------------------------------------------------
VITE_SITE_ID=UK
VITE_DEALER_ID=D066080
VITE_LANGUAGE_ID=EN
VITE_CURRENCY=GBP
VITE_CUST_PRICE_CODE=
# Set to "1" to skip pricelist validation (safe for product lookup)
VITE_IGNORE_PL=1
